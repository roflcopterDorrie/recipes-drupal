# MARIADB VARIABLES (The "Setup" instructions for the DB container)
MARIADB_ROOT_PASSWORD=[password]
MARIADB_DATABASE=drupal_db
MARIADB_USER=drupal_user
MARIADB_PASSWORD=[password]

# DRUPAL VARIABLES (The "Connection" instructions for the Drupal container)
DRUPAL_DB_NAME=drupal_db
DRUPAL_DB_USER=[drupal_user]
DRUPAL_DB_PASSWORD=[password]
DRUPAL_DB_HOST=db
DRUPAL_HASH_SALT=[salt]

PORT=80
SECURE_PORT=443

BORG_PASSPHRASE=[secret key]
BORG_REPO=[ssh something]