{
  "$schema": "https://json-schema.org",
  "type": "object",
  "properties": {
    "title": {
      "type": "string"
    },
    "ingredients": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["amount", "ingredient", "category"],
        "properties": {
          "amount": {
            "type": ["string", "number", "null"]
          },
          "ingredient": {
            "type": "string"
          },
          "extra": {
            "type": ["string", "null"]
          },
          "category": {
            "type": "string"
          }
        }
      }
    },
    "steps": {
      "type": "array",
      "items": {
        "type": "string"
      }
    }
  },
  "required": ["title", "ingredients", "steps"]
}
